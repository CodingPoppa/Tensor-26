from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field
import os

app = FastAPI(title="AI Vulnerability Scanner")

# 🔒 Restrict CORS (NO "*")
app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000"],  # change in production
    allow_credentials=True,
    allow_methods=["POST"],
    allow_headers=["*"],
)

# 🔒 Input validation
class ScanRequest(BaseModel):
    diff: str = Field(..., max_length=10000)

class ScanResponse(BaseModel):
    findings: list
    decision: str

# 🔒 Health check
@app.get("/api/health")
def health():
    return {"status": "ok"}

# 🔒 Secure scan endpoint
@app.post("/api/scan", response_model=ScanResponse)
def scan(request: ScanRequest):

    diff = request.diff.strip()

    # 🔒 Basic validation
    if not diff:
        raise HTTPException(status_code=400, detail="Empty diff")

    # 🔒 Prevent huge payload attacks
    if len(diff) > 10000:
        raise HTTPException(status_code=413, detail="Payload too large")

    # 🔒 Mock safe response (replace with your scanner)
    result = {
        "findings": [],
        "decision": "PASS"
    }

    return result
